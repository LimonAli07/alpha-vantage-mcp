# Alpha Vantage MCP Server Environment Variables

# Core Alpha Vantage API (REQUIRED)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Yahoo Finance API (OPTIONAL - Some endpoints work without authentication)
YAHOO_FINANCE_API_KEY=your_yahoo_finance_api_key_here

# EODHD API (for fundamentals, insider transactions, sentiment)
EODHD_API_KEY=your_eodhd_api_key_here

# FinHub API (for news and additional market data)
FINHUB_API_KEY=your_finhub_api_key_here

# Social Media APIs
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here

# News APIs
BLOOMBERG_API_KEY=your_bloomberg_api_key_here
REUTERS_API_KEY=your_reuters_api_key_here

# Instructions:
# 1. Copy this file to .env in the same directory
# 2. Replace the placeholder values with your actual API keys
# 3. Only ALPHA_VANTAGE_API_KEY is required for basic functionality
# 4. Other API keys enable additional features but are optional